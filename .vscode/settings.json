{
  // 依存は各サービスの Docker コンテナ内にある。ホストで型解決したい場合は
  // 各 TS サービスで一度 `pnpm install`（node-linker=hoisted）すると node_modules が実体で入る。

  // Python(model/notebook)は科学系ライブラリの型スタブが不完全なため型チェックは off。
  // 補完・定義ジャンプ・import 解決は効いたまま。
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.ignore": ["**/ipython_startup.py"],

  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  },

  // エディタの TypeScript をワークスペース版(= services/backend の TS)に固定する。
  // 未指定だと VS Code 同梱版(6.x 等)が使われ、CI の tsc(5.x) と挙動がズレる（@types 自動 include 廃止など）。
  "typescript.tsdk": "services/backend/node_modules/typescript/lib"
}
